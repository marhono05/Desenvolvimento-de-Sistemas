unit Unit1;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls;

type
  TForm1 = class(TForm)
    Label1: TLabel;
    Label2: TLabel;
    Label3: TLabel;
    edtNome: TEdit;
    edtPeso: TEdit;
    edtAltura: TEdit;
    btnCalcular: TButton;
    lblResultado: TLabel;
    Label4: TLabel;
    procedure btnCalcularClick(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form1: TForm1;

implementation

{$R *.dfm}

procedure TForm1.btnCalcularClick(Sender: TObject);
  var
  nome: String;
  peso: Double;
  altura: Double;
  resultadoIMC: Double;

begin
  peso := StrToFloat(edtPeso.Text);
  altura := StrToFloat(edtAltura.Text);
  resultadoIMC := peso / (altura * altura);
  lblResultado.Caption := FloatToStr(resultadoIMC);

  if resultadoIMC <= 18 then
    ShowMessage('Seu IMC Õ ' +  FloatToStr(resultadoIMC) + sLineBreak + 'Vocõ Õ magrelo!')

  else if resultadoIMC <= 24.9 then 
    ShowMessage('Seu IMC Õ ' + FloatToStr(resultadoIMC) + sLineBreak + 'Vocõ estÃ saudÃvel!')

  else if resultadoIMC <= 29.9 then
     ShowMessage('Seu IMC Õ ' + FloatToStr(resultadoIMC) + sLineBreak + 'Vocõ Õ gordinho!')

  else if resultadoIMC <= 39.9 then
       ShowMessage('Seu IMC Õ ' + FloatToStr(resultadoIMC) + sLineBreak + 'Vocõ Õ obeso!')
  else
    ShowMessage('Seu IMC Õ ' + FloatToStr(resultadoIMC) + sLineBreak + 'Vocõ Õ IMENSO!')

       
end;

end.
